# ----- Redis LangCache (managed) -----
# Find these on app.redislabs.com → LangCache → your service.

# Host is the bare hostname of your LangCache service (no protocol, no trailing slash).
# e.g. cache-mpprjdwa.westus2.redislabs.com
LANGCACHE_HOST=

# Full Cache ID from the "Cache ID" column in the LangCache services list.
LANGCACHE_CACHE_ID=

# API key starting with `lc1_...`.
LANGCACHE_API_KEY=

# Similarity threshold (0..1). HIGHER = stricter match.
# 0.9 is the official default and a good starting point.
LANGCACHE_SIMILARITY_THRESHOLD=0.9

# ----- Gemini (Google AI Studio) -----
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-flash-latest

# ----- Server -----
PORT=3000

# Cost tuning for the displayed "savings" metric.
# Default: $0.0001 per LLM call (rough Gemini Flash estimate).
ESTIMATED_COST_PER_LLM_CALL_USD=0.0001
